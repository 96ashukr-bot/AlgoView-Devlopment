APP_ENV=production
DEBUG=False

DJANGO_SECRET_KEY=change-me
ALLOWED_HOSTS=admin.algoview.in,sparksadmin.algoview.in
CSRF_TRUSTED_ORIGINS=https://admin.algoview.in,https://sparksadmin.algoview.in
CORS_ALLOWED_ORIGINS=https://admin.algoview.in,https://sparksadmin.algoview.in
FRONTEND_APP_URL=https://admin.algoview.in

DB_ENGINE=django.db.backends.postgresql
DB_NAME=algoview
DB_USER=algoview
DB_PASSWORD=change-me
DB_HOST=change-me.rds.amazonaws.com
DB_PORT=5432

REDIS_URL=redis://change-me.cache.amazonaws.com:6379/1
CELERY_BROKER_URL=redis://change-me.cache.amazonaws.com:6379/0
CELERY_RESULT_BACKEND=redis://change-me.cache.amazonaws.com:6379/0

WEBHOOK_SECRET=change-me
BROKER_ENCRYPTION_KEYS=change-me-32-byte-base64-fernet-key

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=change-me
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=no-reply@example.com

BROKER_REDIRECT_URL=https://admin.algoview.in/api/auth-callback/
UPSTOX_REDIRECT_URL=https://admin.algoview.in/api/auth-callback/

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
X_FRAME_OPTIONS=DENY

RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
